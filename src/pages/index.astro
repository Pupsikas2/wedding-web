---
import Layout from "../layouts/Layout.astro";
import GutterDecor from "../components/GutterDecor.astro";
---

<Layout title="Wedding">
  <!-- full-page backdrop: clouds & stars scattered down the desktop gutters beside the phone canvas -->
  <div class="relative min-h-screen w-full flex justify-center bg-sand overflow-hidden">
    <!-- ===== desktop-only gutter decorations (shared with /rsvp) ===== -->
    <GutterDecor />

    <!-- phone-width canvas — a CSS container, so all cqw font sizes scale to THIS width, not the browser window -->
    <div
      class="relative z-10 w-full max-w-[480px] bg-sand shadow-2xl"
      style="container-type: inline-size;"
    >

    <section
      class="relative max-w-[900px] mx-auto z-10 bg-sand flex flex-col items-center justify-center"
      style="min-height: max(100svh, 210cqw);"
    >
      <!-- ===== decorations, anchored to the full-height hero panel ===== -->
      <!-- top-left star -->
      <img src="/assets/star-1.svg" alt="" aria-hidden="true"
        class="absolute top-[6%] left-[9%] w-[25%] pointer-events-none" />
      <!-- top-right cupid, facing inward -->
      <img src="/assets/kupidons.png" alt="" aria-hidden="true"
        class="absolute top-[2%] right-[10%] w-[50%] -scale-x-100 -rotate-12 pointer-events-none" />
      <!-- upper-left cloud -->
      <img src="/assets/cloud-8-t.png" alt="" aria-hidden="true"
        class="absolute top-[15%] left-[10%] w-[40%] pointer-events-none" />
      <!-- star to the right of the mirror -->
      <img src="/assets/star-2.svg" alt="" aria-hidden="true"
        class="absolute top-[58%] right-[1%] w-[25%] pointer-events-none" />
      <!-- small star below the heading, on the left -->
      <img src="/assets/star-5.svg" alt="" aria-hidden="true"
        class="absolute bottom-[16%] left-[6%] w-[25%] pointer-events-none" />
      <!-- wide cloud bleeding off the bottom -->
      <img src="/assets/cloud-3-t.png" alt="" aria-hidden="true"
        class="absolute bottom-[5%] left-1/2 -translate-x-1/2 w-[70%] pointer-events-none" />

      <!-- ===== centered content: mirror + heading ===== -->
      <div class="relative z-10 flex flex-col items-center px-6 w-full">
        <img
          src="/assets/lovers.svg"
          alt="Jaunieji"
          class="top-[20%] w-[95%] max-w-[360px] h-auto block"
        />
        <p
          class="font-playfair font-bold text-center leading-[1.05]"
          style="font-size: clamp(2.2rem, 9cqw, 4rem);"
        >
          Mes sakome<br /><span class="text-wine">taip</span>!
        </p>
      </div>
    </section>

    <!-- Red section — height is content-driven (width-based padding), NOT viewport-height,
         so the space around the content + the clip edge scale with the frame like everything else -->
    <section
      class="relative max-w-[900px] mx-auto py-[35%] bg-wine flex flex-col items-center"
      style="z-index: 0;"
    >
      <!-- Centered content column -->
      <div
        class="relative z-10 flex flex-col items-center gap-4 px-8 text-center"
      >
        <p
          class="font-raleway text-sand leading-[1.06] max-w-[9em]"
          style="font-size: clamp(2rem, 8cqw, 3.4rem);"
        >
          Su dideliu džiaugsmu norime pakviesti Jus į savo vestuves
        </p>
        <img
          src="/assets/calendar.png"
          alt="Data"
          class="w-[90%]"
        />
        <p
          class="font-raleway text-sand leading-[1.06] max-w-[9em]"
          style="font-size: clamp(2rem, 8cqw, 3.4rem);"
        >
          Labai jūsų lauksime!
        </p>
        <!-- disco balls anchored to the content block (not the full-height section),
             so their vertical position tracks the text/calendar at every screen size -->
        <img
          src="/assets/disco.svg"
          alt=""
          aria-hidden="true"
          class="swing absolute -z-10 w-[50%] -top-[55%] -left-[6%]"
        />
        <img
          src="/assets/disco.svg"
          alt=""
          aria-hidden="true"
          class="swing absolute -z-10 w-[50%] top-[62%] -right-[6%]"
          style="animation-delay: -1.6s;"
        />
        <img
          src="/assets/disco.svg"
          alt=""
          aria-hidden="true"
          class="swing absolute -z-10 w-[30%] -top-[30%] right-[2%]"
          style="animation-delay: -0.8s;"
        />
      </div>
    </section>

    <!-- ===== PANEL 3: Detalės + Greetings + RSVP (min one screen, grows taller) ===== -->
    <div class="min-h-[100svh]">
    <!-- ===== DETALĖS + schedule ===== -->
    <section class="relative max-w-[900px] mx-auto px-6 pt-12 pb-10">
      <!-- two stars flanking the heading on the left -->
      <img src="/assets/star-5.svg" alt="" aria-hidden="true"
        class="absolute top-[12%] left-[8%] w-[25%] rotate-[25deg] pointer-events-none" />
      <!-- star top-right, above the cat -->
      <img src="/assets/star-1.svg" alt="" aria-hidden="true"
        class="absolute top-[2%] right-[9%] w-[25%] -rotate-12 pointer-events-none" />
      <!-- star lower-right, by the schedule -->
      <img src="/assets/star-5.svg" alt="" aria-hidden="true"
        class="absolute bottom-[7%] right-[7%] w-[25%] pointer-events-none" />

      <h2
        class="font-playfair font-bold text-center tracking-[0.15em] relative z-10 -mt-4"
        style="font-size: clamp(2rem, 7cqw, 3.5rem);"
      >
        DETALĖS
      </h2>

      <!-- ginger cat lounging on a cloud, upper right -->
      <div class="float-hover absolute right-[1%] top-[35%] w-[44%] pointer-events-none">
        <img src="/assets/cloud-2-t.png" alt="" aria-hidden="true" class="w-full" />
        <img src="/assets/ginger-cat-t.png" alt="" aria-hidden="true"
          class="absolute -bottom-[30%] left-1/2 -translate-x-1/2 w-[86%] max-w-[250px]" />
      </div>

      <!-- schedule -->
      <div class="relative z-10 flex flex-col items-center text-center gap-7 pt-[30%] sm:pt-[24%]">
        <div>
          <p class="font-raleway font-bold" style="font-size: clamp(1.1rem, 3cqw, 1.6rem);">
            14:00 – Santuoka
          </p>
          <p class="font-raleway text-neutral-800" style="font-size: clamp(0.85rem, 2.2cqw, 1.15rem);">
            Kauno Švč. Mergelės Ėmimo į<br />dangų bažnyčia (Vytauto Didžiojo)
          </p>
        </div>
        <div>
          <p class="font-raleway font-bold" style="font-size: clamp(1.1rem, 3cqw, 1.6rem);">
            17:00 – Šventė
          </p>
          <p class="font-raleway text-neutral-800" style="font-size: clamp(0.85rem, 2.2cqw, 1.15rem);">
            Vynvytis Studio<br />R. Kalantos g. 34A, Kaunas
          </p>
        </div>
      </div>

      <!-- bushy cloud bottom-left -->
      <img src="/assets/cloud-6-t.png" alt="" aria-hidden="true"
        class="absolute -bottom-[2%] -left-[6%] w-[34%] pointer-events-none" />
    </section>

    <!-- ===== Greetings + dress code + gift ===== -->
    <section class="relative max-w-[900px] mx-auto px-6 py-10">
      <!-- big cloud, upper right -->
      <img src="/assets/cloud-8-t.png" alt="" aria-hidden="true"
        class="absolute top-[2%] -right-[14%] w-[40%] pointer-events-none" />
      <!-- big puffy star lower-left -->
      <img src="/assets/star-1.svg" alt="" aria-hidden="true"
        class="absolute top-[5%] left-[4%] w-[25%] pointer-events-none" />
      <!-- 5-point star lower-right -->
      <img src="/assets/star-2.svg" alt="" aria-hidden="true"
        class="absolute top-[90%] right-[5%] w-[25%] pointer-events-none" />

      <div class="relative z-10 flex flex-col items-center text-center gap-9">
        <p class="font-raleway" style="font-size: clamp(1rem, 2.6cqw, 1.4rem);">
          Sveikinimai vyks šventėje!
        </p>

        <div class="flex flex-col items-center gap-4">
          <p class="font-raleway" style="font-size: clamp(1rem, 2.6cqw, 1.4rem);">
            Dress code – spalvos:
          </p>
          <div class="flex items-center gap-2">
            {[ 'color1', 'color2', 'color3', 'color4' ].map((c) => (
              <img src={`/assets/${c}.png`} alt="" aria-hidden="true"
                class="w-9 h-9 sm:w-11 sm:h-11 object-contain" />
            ))}
          </div>
        </div>

        <p class="font-raleway text-neutral-800 max-w-[28rem]" style="font-size: clamp(0.9rem, 2.3cqw, 1.2rem);">
          Geriausia dovana – Jūsų buvimas šalia…ir ta, kuri<br />telpa į vokelį.
          Gėlės – tegul jos žydi pievose!
        </p>
      </div>

      <!-- tall cloud bottom-left -->
      <img src="/assets/cloud-4-t.png" alt="" aria-hidden="true"
        class="absolute -bottom-[4%] -left-[4%] w-[26%] pointer-events-none" />
    </section>

    <!-- ===== RSVP + closing ===== -->
    <section class="relative max-w-[900px] mx-auto px-6 pt-8 pb-12">
      <div class="relative z-10 flex flex-col items-center text-center gap-7">
        <!-- shooting star between the date and the button, on the left -->
        <img src="/assets/star-3.svg" alt="" aria-hidden="true"
          class="absolute left-[4%] top-[26%] w-[25%] -rotate-6 pointer-events-none" />
        <p class="font-raleway" style="font-size: clamp(0.95rem, 2.4cqw, 1.25rem);">
          Atsakymų lauksime iki 2026 m.<br />liepos 1 d.
        </p>

        <!-- RSVP form lives on its own page (/rsvp) -->
        <a
          href="/rsvp"
          class="inline-block bg-wine text-sand font-playfair font-black tracking-[0.04em] rounded-full shadow-md hover:brightness-110 transition px-16 py-3"
          style="font-size: clamp(1.8rem, 6cqw, 2.8rem);"
        >
          RSVP
        </a>
      </div>

      <!-- fat cat snoozing on a cloud at the very bottom -->
      <div class="float-hover relative z-0 mt-20 ml-[2%] w-[64%] max-w-[440px]">
        <img src="/assets/cloud-3-t.png" alt="" aria-hidden="true" class="w-full" />
        <img src="/assets/fat-cat.png" alt="" aria-hidden="true"
          class="absolute -bottom-[35%] left-1/2 -translate-x-1/2 w-[60%]" />
      </div>
    </section>
    </div>
    <!-- ===== end PANEL 3 ===== -->
    </div><!-- end phone canvas -->
  </div><!-- end desktop backdrop -->
</Layout>

<style>
  /* gentle pendulum swing for the disco balls in the red section */
  .swing {
    transform-origin: top center;
    animation: swing 4.5s ease-in-out infinite;
  }
  @keyframes swing {
    0%, 100% { transform: rotate(-6deg); }
    50%      { transform: rotate(6deg); }
  }

  /* gentle up-and-down hover for the cat-on-cloud */
  .float-hover {
    animation: floaty 4s ease-in-out infinite;
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .swing, .float-hover { animation: none; }
  }
</style>
