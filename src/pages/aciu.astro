---
import Layout from "../layouts/Layout.astro";
import GutterDecor from "../components/GutterDecor.astro";
---

<Layout title="Ačiū!">
  <!-- same full-page backdrop + gutter decorations as the landing/RSVP -->
  <div class="relative min-h-screen w-full flex justify-center bg-sand overflow-hidden">
    <GutterDecor stars={10} clouds={3} />

    <div class="relative z-10 w-full max-w-[480px] min-h-screen bg-sand shadow-2xl flex items-center justify-center px-6">
      <div class="text-center flex flex-col items-center gap-6">
        <img src="/assets/lovers.svg" alt="" class="w-[85%] max-w-[380px] h-auto" />
        <h1 class="font-playfair font-black text-wine" style="font-size: clamp(2.4rem, 12vw, 3.5rem);">
          Ačiū!
        </h1>
        <p class="font-raleway" style="font-size: clamp(1rem, 4.5vw, 1.35rem);">
          Jūsų atsakymas gautas.<br />Labai jūsų lauksime!
        </p>
        <a href="/" class="font-raleway underline text-wine" style="font-size: clamp(0.95rem, 4vw, 1.15rem);">
          Grįžti į pradžią
        </a>
      </div>
    </div>
  </div>
</Layout>
