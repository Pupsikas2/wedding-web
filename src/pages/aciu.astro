---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Ačiū!">
  <div class="min-h-screen w-full flex items-center justify-center bg-sand px-6">
    <div class="max-w-[480px] text-center flex flex-col items-center gap-6">
      <img src="/assets/lovers.svg" alt="" class="w-[60%] max-w-[240px] h-auto" />
      <h1 class="font-playfair font-black text-wine" style="font-size: clamp(2.4rem, 12vw, 3.5rem);">
        Ačiū!
      </h1>
      <p class="font-raleway" style="font-size: clamp(1rem, 4.5vw, 1.35rem);">
        Jūsų atsakymas gautas.<br />Labai jūsų lauksime!
      </p>
      <a href="/" class="font-raleway underline text-wine" style="font-size: clamp(0.95rem, 4vw, 1.15rem);">
        Grįžti į pradžią
      </a>
    </div>
  </div>
</Layout>
